// Vitality - database schema
// Normalizes Garmin / Whoop / Strava / Apple Health into one shared model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  dateOfBirth     DateTime?
  sex             String?
  city            String?
  isPrivate       Boolean   @default(false)
  isBanned        Boolean   @default(false)
  role            String    @default("user")
  heightCm        Float?
  weightKg        Float?
  timezone        String?  @default("America/Los_Angeles")
  goals           Goal[]
  cardiacFlags    String[] @default([])
  accounts        Account[]
  sessions        Session[]
  connections     DeviceConnection[]
  dailyMetrics    DailyMetrics[]
  activities      Activity[]
  adviceCards     AdviceCard[]
  chatMessages    ChatMessage[]
  raceTargets     RaceTarget[]
  trainingPlans   TrainingPlan[]
  passwordResetTokens PasswordResetToken[]
  raceRegistrations RaceRegistration[]
  eventMessages     EventMessage[]
  teamMembers              TeamMember[]
  teamMessages             TeamMessage[]
  teamChallengeEntries     TeamChallengeEntry[]
  teamInvitations          TeamInvitation[] @relation("InvitationReceived")
  sentInvitations          TeamInvitation[] @relation("InvitationSent")
  supportTickets           SupportTicket[]
  directMessagesSent       DirectMessage[]  @relation("DMsSent")
  directMessagesReceived   DirectMessage[]  @relation("DMsReceived")
  adminMessages            AdminMessage[]   @relation("AdminMsgsReceived")
  teamBulletins            TeamBulletin[]
  teamEvents               TeamEvent[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum DataSource {
  GARMIN
  WHOOP
  STRAVA
  APPLE_HEALTH
  MANUAL
}

model DeviceConnection {
  id            String     @id @default(cuid())
  userId        String
  source        DataSource
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  externalUserId String?
  webhookSecret String?
  status        String     @default("active")
  lastSyncedAt  DateTime?
  lastError     String?
  createdAt     DateTime   @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, source])
  @@map("device_connections")
}

model DailyMetrics {
  id     String   @id @default(cuid())
  userId String
  date   DateTime
  source DataSource
  restingHeartRate   Float?
  avgHeartRate       Float?
  maxHeartRate       Float?
  hrvMs              Float?
  hrvSdnnMs          Float?
  sleepScore         Float?
  sleepDurationMin    Float?
  sleepDeepMin        Float?
  sleepRemMin         Float?
  sleepLightMin       Float?
  sleepAwakeMin       Float?
  respirationRate    Float?
  spo2Pct            Float?
  bodyBatteryOrRecoveryPct Float?
  strainOrLoadScore  Float?
  steps              Int?
  activeCalories     Float?
  totalCalories      Float?
  vo2Max             Float?
  bodyWeightKg       Float?
  stressLevel        Float?
  raw    Json?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date, source])
  @@index([userId, date])
  @@map("daily_metrics")
}

model Activity {
  id            String     @id @default(cuid())
  userId        String
  source        DataSource
  externalId    String
  type          String
  startTime     DateTime
  durationSec   Int
  distanceM     Float?
  avgHeartRate  Float?
  maxHeartRate  Float?
  avgPaceSecPerKm Float?
  elevationGainM Float?
  calories      Float?
  trainingLoad  Float?
  perceivedEffort Float?
  title         String?
  raw           Json?
  createdAt     DateTime   @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([source, externalId])
  @@index([userId, startTime])
  @@map("activities")
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  targetDate  DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("goals")
}

model RaceTarget {
  id           String   @id @default(cuid())
  userId       String
  raceName     String
  raceDate     DateTime
  distanceM    Float
  goalTimeSec  Int?
  raceType         String?
  weeklyMileageKm  Float?
  recentRaceTime   String?
  trainingDaysPerWeek Int?
  isTriathlon      Boolean? @default(false)
  trainingPlanJson     Json?
  nutritionPlanCache   Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan TrainingPlan?
  @@map("race_targets")
}

model AdviceCard {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  headline  String
  body      String
  category  String
  severity  String   @default("info")
  metricsSnapshotJson Json?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@map("advice_cards")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@map("chat_messages")
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime?
  note      String?
  teamId    String?
  reusable  Boolean  @default(false)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  @@map("invite_codes")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("password_reset_tokens")
}

model TrainingPlan {
  id          String            @id @default(cuid())
  userId      String
  raceId      String            @unique
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workouts    TrainingWorkout[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  race        RaceTarget        @relation(fields: [raceId], references: [id], onDelete: Cascade)
  @@map("training_plans")
}

model TrainingWorkout {
  id           String    @id @default(cuid())
  planId       String
  date         DateTime
  week         Int
  day          String
  type         String
  title        String
  description  String
  distanceKm   Float?
  durationMin  Int?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  activityId   String?
  plan         TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  @@index([planId, date])
  @@map("training_workouts")
}

model MajorRace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  city         String
  country      String
  raceDate     DateTime
  distanceM    Float
  isTriathlon  Boolean  @default(false)
  series       String?
  website      String?
  status       String   @default("active")
  submittedBy  String?
  createdAt    DateTime @default(now())
  registrations RaceRegistration[]
  teams         Team[]
  messages      EventMessage[]

  @@index([raceDate])

  @@map("major_races")
}

model RaceRegistration {
  id           String   @id @default(cuid())
  userId       String
  majorRaceId  String
  raceTargetId String?
  isPublic     Boolean  @default(true)
  goalTimeSec  Int?
  createdAt    DateTime @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  majorRace    MajorRace  @relation(fields: [majorRaceId], references: [id], onDelete: Cascade)
  @@unique([userId, majorRaceId])
  @@index([majorRaceId, isPublic])
  @@map("race_registrations")
}
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdBy   String
  majorRaceId String?
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())
  members     TeamMember[]
  messages    TeamMessage[]
  challenges  TeamChallenge[]
  invitations TeamInvitation[]
  directMessages DirectMessage[]
  bulletins   TeamBulletin[]
  events      TeamEvent[]
  contacts    TeamContact[]
  inviteCodes InviteCode[]
  majorRace   MajorRace?   @relation(fields: [majorRaceId], references: [id])
  @@map("teams")
}

model TeamBulletin {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  title     String?
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([teamId, createdAt])
  @@map("team_bulletins")
}

model TeamEvent {
  id          String   @id @default(cuid())
  teamId      String
  userId      String
  title       String
  description String?
  eventDate   DateTime
  location    String?
  link        String?
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([teamId, eventDate])
  @@map("team_events")
}

model TeamContact {
  id        String   @id @default(cuid())
  teamId    String
  label     String
  value     String
  type      String   @default("text")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@map("team_contacts")
}

model TeamChallenge {
  id          String   @id @default(cuid())
  teamId      String
  createdBy   String
  title       String
  type        String   // run, walk, swim, bike, steps, custom
  metric      String   // distance, duration, count
  unit        String   // mi, km, min, sessions, steps
  goal        Float?
  goalPerDay  Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  description String?
  isPublic    Boolean  @default(false)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  entries     TeamChallengeEntry[]
  @@map("team_challenges")
}

model TeamChallengeEntry {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  value       Float
  date        DateTime
  note        String?
  createdAt   DateTime @default(now())
  challenge   TeamChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("team_challenge_entries")
}
model TeamMember {
  id               String    @id @default(cuid())
  teamId           String
  userId           String
  role             String    @default("member")
  joinedAt         DateTime  @default(now())
  lastViewedChatAt DateTime?
  team             Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([teamId, userId])
  @@map("team_members")
}
model TeamInvitation {
  id          String   @id @default(cuid())
  teamId      String
  userId      String
  invitedBy   String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation("InvitationReceived", fields: [userId], references: [id], onDelete: Cascade)
  inviter     User     @relation("InvitationSent",     fields: [invitedBy], references: [id], onDelete: Cascade)
  @@unique([teamId, userId])
  @@map("team_invitations")
}

model TeamMessage {
  id          String       @id @default(cuid())
  teamId      String
  userId      String
  content     String
  replyToId   String?
  isDeleted   Boolean      @default(false)
  deletedBy   String?
  createdAt   DateTime     @default(now())
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo     TeamMessage? @relation("teamReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     TeamMessage[] @relation("teamReplies")
  @@index([teamId, createdAt])
  @@map("team_messages")
}

model DirectMessage {
  id          String   @id @default(cuid())
  teamId      String
  fromUserId  String
  toUserId    String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser    User     @relation("DMsSent",      fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("DMsReceived",  fields: [toUserId],   references: [id], onDelete: Cascade)
  @@index([teamId, toUserId, createdAt])
  @@index([toUserId, isRead])
  @@map("direct_messages")
}

model Setting {
  key   String @id
  value String
  @@map("settings")
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  category    String   @default("general")
  status      String   @default("open")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("support_tickets")
}

model AdminMessage {
  id        String   @id @default(cuid())
  toUserId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  toUser    User     @relation("AdminMsgsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  @@index([toUserId, isRead])
  @@map("admin_messages")
}

model Announcement {
  id           String    @id @default(cuid())
  title        String?
  content      String
  createdAt    DateTime  @default(now())
  scheduledFor DateTime?
  expiresAt    DateTime?
  @@map("announcements")
}

model InviteRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  message    String?
  status     String   @default("pending")
  inviteCode String?
  createdAt  DateTime @default(now())
  @@map("invite_requests")
}

model EventMessage {
  id          String         @id @default(cuid())
  majorRaceId String
  userId      String
  content     String
  replyToId   String?
  isDeleted   Boolean        @default(false)
  deletedBy   String?
  createdAt   DateTime       @default(now())
  majorRace   MajorRace      @relation(fields: [majorRaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo     EventMessage?  @relation("eventReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     EventMessage[] @relation("eventReplies")
  @@index([majorRaceId, createdAt])
  @@map("event_messages")
}
